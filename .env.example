# Clerk (auth)
# Create a JWT template named "convex" in Clerk dashboard (Templates > New > Convex).
# Copy the Issuer URL — paste it as CLERK_JWT_ISSUER_DOMAIN below.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Convex (backend)
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOY_KEY=

# OpenAI (LLM)
OPENAI_API_KEY=

# Observability
# Get your DSN from: Settings > Projects > <project> > Client Keys in Sentry.
# NEXT_PUBLIC_SENTRY_DSN is required for browser + edge reporting.
# SENTRY_DSN is used server-side (optional alias — set both to the same value).
# SENTRY_AUTH_TOKEN is needed for source map uploads during production builds.
# Omit all three for local development or CI without a real Sentry project.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Deploy info surfaced on the public /status page.
# COMMIT_SHA + COMMIT_TIME are set automatically by the Vercel build hook
# (do not set manually). VERCEL_GIT_REPO_OWNER + VERCEL_GIT_REPO_SLUG are
# auto-injected by Vercel and used to build the GitHub commit link.
# COMMIT_SHA=
# COMMIT_TIME=
