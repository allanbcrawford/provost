# Clerk (auth)
# Create a JWT template named "convex" in Clerk dashboard (Templates > New > Convex).
# Copy the Issuer URL — paste it as CLERK_JWT_ISSUER_DOMAIN below.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Convex (backend)
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOY_KEY=

# OpenAI (LLM)
OPENAI_API_KEY=

# Observability
SENTRY_DSN=
